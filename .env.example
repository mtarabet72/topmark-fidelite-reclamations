# Copier ce fichier en ".env" et remplir avec les valeurs de votre projet Appwrite Cloud
# (Console Appwrite > Project Settings)

VITE_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=
VITE_APPWRITE_DATABASE_ID=topmark_main

# Ne jamais committer le fichier ".env" réel — il est dans .gitignore
